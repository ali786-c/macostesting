{
  "name": "mon-projet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "clean": "rm -rf .next",
    "clean:all": "rm -rf .next node_modules package-lock.json && npm install",
    "index": "tsx src/scripts/index-site.ts",
    "test:chatbot": "tsx src/scripts/test-chatbot.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:public": "playwright test e2e/02-pages-public.spec.ts e2e/03-search.spec.ts --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "build:capacitor": "node scripts/capacitor-build.mjs",
    "build:fix": "npm run build:capacitor && npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:sync:ios": "npx cap sync ios",
    "cap:open": "npx cap open android",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:build": "npm run build:capacitor && npx cap sync",
    "ios:dev": "npm run mobile:ios",
    "mobile:android": "npm run build:capacitor && npx cap sync android && npx cap open android",
    "mobile:ios": "npm run build:capacitor && npx cap sync ios && npx cap open ios",
    "build:web": "next build",
    "build:ios": "npm run build:capacitor && npx cap sync ios",
    "build:android": "npm run build:capacitor && npx cap sync android",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "android:release": "cd android && ./gradlew assembleRelease",
    "android:install": "cd android && ./gradlew installDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^8.0.1",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.8.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.12.2",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.548.0",
    "mapbox-gl": "^3.18.1",
    "maplibre-gl": "^5.17.0",
    "next": "^16.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-leaflet": "^4.2.1",
    "react-map-gl": "^8.1.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/cheerio": "^0.22.35",
    "@types/jest": "^29.5.11",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "^16.0.10",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.0.11",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16",
    "tsx": "^4.7.0",
    "typescript": "^5",
    "web-streams-polyfill": "^4.2.0"
  }
}
